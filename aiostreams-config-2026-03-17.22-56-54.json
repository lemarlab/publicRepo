  "formatter": {
    "id": "gdrive",
    "definition": {
      "name": "{stream.resolution::exists[\" {stream.resolution}\"||\"\"]}\n{stream.quality::~remux[\" · \"||\"\"]}{stream.quality::exists[\" · {stream.quality}\"||\"\"]}\n{stream.visualTags::exists[\" 🔆 {stream.visualTags::join(' / ')}\"||\"\"]}",
      "description": "🎬 {stream.title::exists[\"{stream.title}\"||\"{stream.filename}\"]} {stream.year::exists[\"({stream.year})\"||\"\"]} {stream.season::>=0[\" · S\"||\"\"]}{stream.season::<=9[\"0\"||\"\"]}{stream.season::>0[\"{stream.season}\"||\"\"]}{stream.episode::>=0[\"E\"||\"\"]}{stream.episode::<=9[\"0\"||\"\"]}{stream.episode::>0[\"{stream.episode}\"||\"\"]}{service.id::exists[\" · [{service.shortName}\"||\"\"]}{service.cached::istrue[\"⚡] \"||\"\"]}{service.cached::isfalse[\" ❌] \"||\"\"]}\n\n🎞️ {stream.quality::exists[\"{stream.quality}\"||\"\"]}{stream.visualTags::exists[\" · {stream.visualTags::join(' / ')}\"||\"\"]}{stream.resolution::exists[\" · {stream.resolution}\"||\"\"]}{stream.encode::exists[\" · {stream.encode}\"||\"\"]}\n\n🔊 {stream.audioTags::exists[\"{stream.audioTags::join(' / ')}\"||\"\"]}{stream.audioChannels::exists[\" · {stream.audioChannels::join(' / ')}\"||\"\"]} · 📦 {stream.size::>0[\"{stream.size::bytes2}\"||\"\"]} 🔌 {addon.name::exists[\"{addon.name}\"||\"\"]}{stream.releaseGroup::exists[\" · 👥 {stream.releaseGroup}\"||\"\"]}{stream.regexMatched::exists[\" · 🌟 {stream.regexMatched}\"||\"\"]}"
    }
